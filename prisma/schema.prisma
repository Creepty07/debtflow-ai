// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Lifecycle state of a collection case.
enum InvoiceStatus {
  PENDING          // no contact yet
  IN_PROGRESS      // agent actively working
  ESCALATED_HUMAN  // exceeded agent limits, handed to human
  PAID
  WRITTEN_OFF      // uncollectable
}

/// Escalation tier driven by days overdue.
enum EscalationLevel {
  LEVEL_1 // days 1-7, friendly tone
  LEVEL_2 // days 8-21, direct tone
  LEVEL_3 // days 22+, formal tone
}

/// Outbound messaging channel.
enum Channel {
  EMAIL
  WHATSAPP
}

/// A debtor company. One client owns many invoices.
model Client {
  id           String    @id @default(cuid())
  companyName  String
  contactEmail String
  contactPhone String? // optional — WhatsApp deferred to Phase 2
  riskProfile  String? // free-text debtor profile for agent reasoning
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  invoices     Invoice[]
}

/// A receivable being pursued by the agent.
model Invoice {
  id              String           @id @default(cuid())
  clientId        String
  client          Client           @relation(fields: [clientId], references: [id])
  amount          Decimal          @db.Decimal(12, 2) // Decimal, never Float — money requires exact precision
  issueDate       DateTime
  dueDate         DateTime
  status          InvoiceStatus    @default(PENDING)
  escalationLevel EscalationLevel  @default(LEVEL_1)
  nextActionAt    DateTime? // cron trigger; null means no pending automated action
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  contactAttempts ContactAttempt[]
  agentLogs       AgentLog[]

  @@index([nextActionAt]) // cron queries WHERE nextActionAt <= NOW() — full scan without this
  @@index([status])
}

/// A single outbound collection message sent to the debtor.
/// The agent reads this history to decide what to try next.
model ContactAttempt {
  id              String          @id @default(cuid())
  invoiceId       String
  invoice         Invoice         @relation(fields: [invoiceId], references: [id])
  channel         Channel
  escalationLevel EscalationLevel
  subject         String? // email only
  body            String          @db.Text // may exceed varchar limit
  sentAt          DateTime        @default(now())
  delivered       Boolean         @default(false)
  opened          Boolean         @default(false) // Resend webhook tracking
  responded       Boolean         @default(false)

  @@index([invoiceId])
}

/// Agent reasoning record for a single decision cycle.
/// Separate from ContactAttempt: action (what was sent) vs. decision (why it was chosen).
/// Written by the logging Decorator; primary tool for production debugging.
model AgentLog {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id])
  observation String   @db.Text // state the agent observed before deciding
  reasoning   String   @db.Text // why the agent chose this action
  toolCalled  String? // name of the tool invoked, if any
  toolArgs    Json? // varies per tool — rigid schema would not fit all 6
  toolResult  Json? // varies per tool
  createdAt   DateTime @default(now())

  @@index([invoiceId])
}

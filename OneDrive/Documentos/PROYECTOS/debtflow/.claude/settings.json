{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npx prisma *)",
      "Bash(git *)",
      "Bash(npm install *)",
      "Bash(mkdir *)",
      "Bash(echo *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f package.json ] && (npm run lint 2>&1; npm test 2>&1) || echo 'No package.json aun'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -f package.json ] && npm test 2>&1 || echo 'Sin tests aun - OK'"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "caveman@caveman": true,
    "andrej-karpathy-skills@karpathy-skills": true,
    "ui-ux-pro-max@ui-ux-pro-max-skill": true
  }
}